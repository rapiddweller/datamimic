<setup>
    <generate name="library" source="data/library.json" target="JSON, ConsoleExporter">
        <generate name="books" script="library.books" target="XML, ConsoleExporter">

            <!-- Nested key for book details -->
            <nestedKey name="book_details" type="dict">
                <key name="book_id" type="string" script="library.books[0].id"/>
                <key name="title" type="string" script="library.books[0].title"/>
                <key name="genre" type="string" script="library.books[0].genre"/>

                <!-- Nested key for authors -->
                <nestedKey name="authors" type="dict">
                    <key name="author_name" type="string" script="library.books[0].authors[0].name"/>
                    <key name="author_country" type="string" script="library.books[0].authors[0].country"/>
                </nestedKey>
            </nestedKey>

            <!-- Nested key for publisher -->
            <nestedKey name="publisher_details" type="dict">
                <key name="publisher_name" type="string" script="library.books[0].publisher.name"/>
                <key name="publisher_location" type="string" script="library.books[0].publisher.location"/>
                <key name="publisher_year" type="int" script="library.books[0].publisher.year"/>
            </nestedKey>

            <!-- Adding a condition based on the genre -->
            <key name="is_science_fiction" type="bool" condition="library.books[0].genre == 'Science Fiction'"/>
        </generate>

        <!-- Generate filtered books based on genre (manually defined condition) -->
        <generate name="filtered_books" script="library.books" target="CSV, ConsoleExporter">
            <key name="book_id" type="string" script="library.books[0].id"
                 condition="library.books[0].genre == 'Science Fiction'"/>
            <key name="title" type="string" script="library.books[0].title"
                 condition="library.books[0].genre == 'Science Fiction'"/>
            <key name="genre" type="string" script="library.books[0].genre"
                 condition="library.books[0].genre == 'Science Fiction'"/>
        </generate>

    </generate>
</setup>